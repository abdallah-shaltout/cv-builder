<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= header.name %> — Senior Full-Stack Developer</title>
  <style>
    @font-face {
      font-family: "Inter";
      src: url("data:font/woff2;base64,<%= fontBase64 %>") format("woff2");
      font-weight: normal;
      font-style: normal;
      font-display: swap;
    }
    :root {
      --ink: #111;
      --body: #2a2a2a;
      --mid: #555;
      --mute: #888;
      --rule: #d4d4d4;
      --accent: #0a4d7a;
      --page-w: 780px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter',  Arial, sans-serif;
      color: var(--body);
      /* background: #efefed; */
      /* padding: 2.5rem 1rem; */
      font-size: 14px;
      line-height: 1.5;
    }
    .page {
      max-width: var(--page-w);
      margin: 0 auto;
      background: #fff;
      padding: 56px 64px;
    }
    .cv-header { margin-bottom: 32px; padding-bottom: 24px; border-bottom: 2px solid var(--ink); }
    .cv-header h1 { font-family: Georgia, 'Times New Roman', serif; font-size: 2.4rem; font-weight: 700; color: var(--ink); letter-spacing: -0.5px; line-height: 1; margin-bottom: 6px; }
    .cv-header .headline { font-size: .9rem; font-weight: 500; color: var(--accent); letter-spacing: .5px; margin-bottom: 14px; }
    .contact-row { display: flex; flex-wrap: wrap; gap: 6px 20px; font-size: .78rem; color: var(--mid); }
    .contact-row a { color: var(--mid); text-decoration: none; }
    .contact-row a:hover { color: var(--accent); text-decoration: underline; }
    .contact-row span { display: flex; align-items: center; gap: 5px; }
    .c-icon { width: 12px; height: 12px; opacity: .5; flex-shrink: 0; }
    .section { margin-bottom: 28px; }
    .section:last-child { margin-bottom: 0; }
    .section-title { font-size: .68rem; font-weight: 600; letter-spacing: 2.5px; text-transform: uppercase; color: var(--mute); border-bottom: 1px solid var(--rule); padding-bottom: 6px; margin-bottom: 16px; }
    .summary { font-size: .88rem; line-height: 1.75; color: var(--body); }
    .summary strong { color: var(--ink); font-weight: 600; }
    .skills-table { width: 100%; border-collapse: collapse; }
    .skills-table tr { vertical-align: top; }
    .skills-table td { padding: 4px 0; font-size: .82rem; line-height: 1.6; border: none; }
    .skills-table td:first-child { width: 160px; font-weight: 600; color: var(--ink); padding-right: 16px; white-space: nowrap; }
    .job { margin-bottom: 22px; }
    .job:last-child { margin-bottom: 0; }
    .job-top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1px; }
    .job-title { font-size: .96rem; font-weight: 700; color: var(--ink); }
    .job-period { font-family: 'JetBrains Mono', monospace; font-size: .72rem; color: var(--mute); white-space: nowrap; }
    .job-meta { font-size: .8rem; color: var(--mid); margin-bottom: 10px; }
    .job-meta a { color: var(--accent); text-decoration: none; }
    .job-meta a:hover { text-decoration: underline; }
    .job-bullets { list-style: none; padding: 0; margin: 0; }
    .job-bullets li { font-size: .83rem; color: var(--body); line-height: 1.65; padding-left: 16px; position: relative; margin-bottom: 5px; }
    .job-bullets li::before { content: '▸'; position: absolute; left: 0; color: var(--accent); font-size: .7rem; top: 2px; }
    .job-bullets li strong { color: var(--ink); font-weight: 600; }
    .project-entry { margin-bottom: 14px; }
    .project-entry:last-child { margin-bottom: 0; }
    .project-top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 3px; gap: 12px; }
    .project-name { font-size: .88rem; font-weight: 700; color: var(--ink); }
    .project-name a { color: var(--accent); text-decoration: none; }
    .project-name a:hover { text-decoration: underline; }
    .project-stack { font-family: 'JetBrains Mono', monospace; font-size: .67rem; color: var(--mute); text-align: right; flex-shrink: 0; }
    .project-desc { font-size: .81rem; color: var(--body); line-height: 1.6; }
    .project-metrics { margin-top: 5px; display: flex; flex-wrap: wrap; gap: 5px; }
    .badge { font-size: .68rem; font-weight: 600; border: 1px solid var(--rule); border-radius: 3px; padding: 1px 7px; color: var(--mid); letter-spacing: .3px; }
    .edu-row { display: flex; justify-content: space-between; align-items: baseline; }
    .edu-degree { font-size: .88rem; font-weight: 700; color: var(--ink); }
    .edu-year { font-family: 'JetBrains Mono', monospace; font-size: .72rem; color: var(--mute); }
    .edu-school { font-size: .8rem; color: var(--mid); margin-top: 2px; }
    /* @media print {
      body { background: #fff; padding: 0; }
      .page { box-shadow: none; padding: 32px 44px; }
      a { color: inherit !important; }
    }
    @media (max-width: 600px) {
      .page { padding: 28px 20px; }
      .job-top, .project-top, .edu-row { flex-direction: column; gap: 2px; }
      .project-stack { text-align: left; }
    } */
  </style>
</head>
<body>
<div class="page">

  <!-- HEADER -->
  <header class="cv-header">
    <h1><%= header.name %></h1>
    <div class="headline"><%= header.headline %></div>
    <div class="contact-row">
      <% header.contact.forEach(function(c) { %>
      <span>
        <svg class="c-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 11.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 0.72h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.29 6.29l.16-.93z"/></svg>
        <% if (c.href) { %><a href="<%= c.href %>" target="_blank"><%= c.text %></a><% } else { %><%= c.text %><% } %>
      </span>
      <% }); %>
    </div>
  </header>

  <!-- PROFESSIONAL SUMMARY -->
  <div class="section ">
    <div class="section-title">Professional Summary</div>
    <p class="summary"><%- summary %></p>
  </div>

  <!-- KEY PROJECTS -->
  <div class="section">
    <div class="section-title">Key Projects</div>
    <% projects.forEach(function(p) { %>
    <div class="project-entry">
      <div class="project-top">
        <span class="project-name">
          <% if (p.link) { %><a href="<%= p.link %>" target="_blank"><%= p.name %></a><% } else { %><%= p.name %><% } %> — <%= p.subtitle %>
        </span>
        <span class="project-stack"><%= p.stack %></span>
      </div>
      <div class="project-desc"><%= p.description %></div>
      <div class="project-metrics">
        <% p.badges.forEach(function(b) { %><span class="badge"><%= b %></span><% }); %>
      </div>
    </div>
    <% }); %>
  </div>

  <!-- PROFESSIONAL EXPERIENCE -->
  <div class="section">
    <div class="section-title">Professional Experience</div>
    <% jobs.forEach(function(job) { %>
    <div class="job">
      <div class="job-top">
        <span class="job-title"><%= job.title %></span>
        <span class="job-period"><%= job.period %></span>
      </div>
      <div class="job-meta"><%- job.meta %></div>
      <ul class="job-bullets">
        <% job.bullets.forEach(function(b) { %>
        <li><%- b %></li>
        <% }); %>
      </ul>
    </div>
    <% }); %>
  </div>

  <!-- TECHNICAL SKILLS -->
  <div class="section">
    <div class="section-title">Technical Skills</div>
    <table class="skills-table" role="presentation">
      <% skills.forEach(function(s) { %>
      <tr><td><%= s.category %></td><td><%= s.items %></td></tr>
      <% }); %>
    </table>
  </div>

  <!-- EDUCATION -->
  <div class="section">
    <div class="section-title">Education</div>
    <div class="edu-row">
      <span class="edu-degree"><%= education.degree %></span>
      <span class="edu-year"><%= education.year %></span>
    </div>
    <div class="edu-school"><%= education.school %></div>
  </div>

  <!-- LANGUAGES -->
  <div class="section">
    <div class="section-title">Languages</div>
    <table class="skills-table" role="presentation">
      <% languages.forEach(function(l) { %>
      <tr><td><%= l.lang %></td><td><%= l.level %></td></tr>
      <% }); %>
    </table>
  </div>

</div>
</body>
</html>
